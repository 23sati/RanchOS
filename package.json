{
  "name": "ranchos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "cross-env NEXT_TELEMETRY_DISABLED=1 EXPO_TELEMETRY_DISABLED=1 turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "drizzle-kit generate --config=packages/db/drizzle.config.ts",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:seed": "tsx packages/db/src/seed.ts"
  },
  "devDependencies": {
    "@better-auth/core": "^1.5.6",
    "@better-auth/utils": "^0.3.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
